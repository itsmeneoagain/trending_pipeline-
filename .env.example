# ─── YouTube ──────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Reddit (OPTIONAL — RSS feeds are used by default, no key needed) ──
# Only needed if RSS fails and you want PRAW fallback.
# Getting API access requires approval: https://support.reddithelp.com/hc/en-us/articles/42728983564564
# Leave blank to use RSS-only mode (recommended).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendingPipeline/1.0

# ─── Notion ───────────────────────────────────────────────
# Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_notion_integration_token_here

# Database IDs — find in the URL of each database page
# https://www.notion.so/workspace/DATABASE_ID_HERE?v=...
NOTION_TRENDING_DB_ID=your_32char_trending_database_id
NOTION_PIPELINE_DB_ID=your_32char_pipeline_database_id
NOTION_CREATORS_DB_ID=your_32char_creators_database_id

# ─── Gemini API (optional) ────────────────────────────────
# Optional: for AI-powered curation layer (content hooks & angles)
# Get a free key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Creator Tracking (optional) ─────────────────────────
# Comma-separated YouTube channel IDs to track
# Find a channel ID: go to a channel → About → Share → copy the /channel/UC... part
CREATOR_CHANNEL_IDS=

